```gitignore
# Compiled and binary files
*.pyc
__pycache__/
*.o
*.obj
*.exe
*.dll
*.so
*.a
*.out

# Dependencies
node_modules/
venv/
.venv/
.env
.env.local
*.env.*

# Build artifacts
dist/
build/
target/
*.log
coverage/
htmlcov/
.coverage

# Editors and IDEs
.vscode/
.idea/
*.swp
*.swo
*.tmp

# System files
.DS_Store
Thumbs.db

# Compression and archives
*.zip
*.gz
*.tar
*.tgz
*.bz2
*.xz
*.7z
*.rar
*.zst
*.lz4
*.lzh
*.cab
*.arj
*.rpm
*.deb
*.Z
*.lz
*.lzo
*.tar.gz
*.tar.bz2
*.tar.xz
*.tar.zst

# Python specific
*.pyo
*.pyd
*.egg-info/
.pytest_cache/
.mypy_cache/

# Java specific
*.class
*.jar
.gradle/

# JavaScript/Node specific
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Go specific
*.out

# C/C++ specific
*.a
*.lib
*.obj
*.o
*.so
*.dylib
*.dll

# Ruby specific
*.gem
*.rbc
.bundle/
vendor/bundle/

# Rust specific
*.rlib
target/

# Julia specific
julia-*/

# Zig specific
zig*/
```