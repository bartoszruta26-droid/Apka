```gitignore
# Compiled and build artifacts
*.pyc
__pycache__/
*.o
*.obj
*.class
*.exe
*.dll
*.so
*.a
*.out

# Dependencies
node_modules/
venv/
.venv/
.env
.env.local
*.env.*

# Build directories
dist/
build/
target/
*.jar
*.war
*.ear

# Logs and temporary files
*.log
*.tmp
*.swp
*.swo

# Editors and IDEs
.vscode/
.idea/
*.iml
*.ipr
*.iws

# System files
.DS_Store
Thumbs.db

# Coverage and testing
.coverage
coverage/
htmlcov/

# Python specific
*.pyc
__pycache__/
*.pyo
*.pyd
.Python
*.so
.Python
*.egg-info/
.eggs/
.mypy_cache/
.pytest_cache/
.tox/

# Node.js specific
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Java specific
*.class
*.jar
*.war
*.ear
target/
.gradle/
build/

# C/C++ specific
*.o
*.a
*.so
*.dll
*.exe
*.out
*.obj

# Compressed files
*.zip
*.gz
*.tar
*.tgz
*.bz2
*.xz
*.7z
*.rar
*.zst
*.lz4
*.lzh
*.cab
*.arj
*.rpm
*.deb
*.Z
*.lz
*.lzo
*.tar.gz
*.tar.bz2
*.tar.xz
*.tar.zst
```